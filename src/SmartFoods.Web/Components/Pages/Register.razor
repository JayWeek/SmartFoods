@page "/register"
@layout MainLayout
@using Microsoft.AspNetCore.Identity
@using SmartFoods.Web.Data
@using SmartFoods.Web.Models

@inject UserManager<ApplicationUser> UserManager
@inject NavigationManager Navigation

@code {
    // Added SupplyParameterFromForm to cleanly bind input data on postback
    [SupplyParameterFromForm]
    public RegisterModel model { get; set; } = new();
    
    private string? errorMessage;

    private async Task HandleRegistration()
    {
        errorMessage = null;

        var user = new ApplicationUser
        {
            FullName = $"{model.FirstName} {model.LastName}".Trim(),
            UserName = model.Email,
            Email = model.Email
        };

        var result = await UserManager.CreateAsync(
            user,
            model.Password
        );

        if (result.Succeeded)
        {
            // Redirect straight to the login page instead of signing them in immediately
            Navigation.NavigateTo("/login");
        }
        else
        {
            errorMessage = string.Join(
                ", ",
                result.Errors.Select(x => x.Description)
            );
        }
    }
}

<PageTitle>Get Started | SmartFoods</PageTitle>

<Navbar />

<div class="auth-page bg-gradient-to-b from-white via-green-50 to-white">
    <div class="register-shell">

        <div class="register-card landing-glass shadow-xl">
            <div class="landing-orb orb-a"></div>
            <div class="landing-orb orb-b"></div>

            <div class="auth-card-content">
                <div class="auth-header">
                    <div class="landing-chip">
                        Smart kitchen onboarding
                    </div>

                    <h2>Create your SmartFoods account</h2>

                    <p>
                        Start managing your pantry smarter and reduce unnecessary food waste.
                    </p>
                </div>

                <EditForm Model="model" OnValidSubmit="HandleRegistration" FormName="RegisterForm" class="auth-form">
                    <DataAnnotationsValidator />
                    <ValidationSummary />
                    
                    <!-- Your perfect split-grid layout is now completely untouched -->
                    <div class="split-grid">
                        <div class="form-group">
                            <label>First Name</label>
                            <input type="text"
                                   @bind-value="model.FirstName"
                                   name="model.FirstName"
                                   placeholder="John" />
                        </div>

                        <div class="form-group">
                            <label>Last Name</label>
                            <input type="text"
                                   @bind-value="model.LastName"
                                   name="model.LastName"
                                   placeholder="Doe" />
                        </div>
                    </div>

                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" 
                               @bind-value="model.Email" 
                               name="model.Email"
                               placeholder="you@example.com" />
                    </div>

                    <div class="split-grid">
                        <div class="form-group">
                            <label>Password</label>
                            <input type="password" 
                                   @bind-value="model.Password" 
                                   name="model.Password"
                                   placeholder="Create password" />
                        </div>

                        <div class="form-group">
                            <label>Confirm Password</label>
                            <input type="password" 
                                   @bind-value="model.ConfirmPassword" 
                                   name="model.ConfirmPassword"
                                   placeholder="Confirm password" />
                        </div>
                    </div>

                    <label class="remember-row terms-row">
                        <input type="checkbox" required />
                        <span>
                            I agree to the Terms of Service and Privacy Policy
                        </span>
                    </label>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="auth-error" style="color: #dc3545; font-weight: 600; font-size: 0.95rem;">
                            @errorMessage
                        </div>
                    }

                    <button type="submit" class="auth-button">
                        Create Account
                    </button>
                </EditForm>

                <div class="auth-footer">
                    Already have an account?
                    <a href="/login">Login</a>
                </div>
            </div>
        </div>

        <div class="register-side">
            <div class="landing-chip">
                Why SmartFoods?
            </div>

            <h1>
                Build a smarter,
                more sustainable kitchen.
            </h1>

            <p>
                SmartFoods helps households reduce food waste using pantry intelligence,
                expiration tracking, and personalized recipe suggestions.
            </p>

            <div class="feature-stack">
                <div class="feature-panel">
                    <div>
                        <h3>Track pantry inventory</h3>
                        <p>Organize ingredients in one clean dashboard.</p>
                    </div>
                </div>

                <div class="feature-panel">
                    <div>
                        <h3>Receive expiry alerts</h3>
                        <p>Know exactly what needs to be used first.</p>
                    </div>
                </div>

                <div class="feature-panel">
                    <div>
                        <h3>Discover intelligent recipes</h3>
                        <p>Cook meals using what you already own.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
