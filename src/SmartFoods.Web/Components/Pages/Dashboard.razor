@page "/dashboard"
@layout MainLayout

@using SmartFoods.Web.Services.Pantry

@inject PantryService PantryService
@inject Microsoft.AspNetCore.Components.Authorization.AuthenticationStateProvider AuthenticationStateProvider

<PageTitle>SmartFoods | Dashboard</PageTitle>

<DashboardShell>
    <section class="sf-section">
        <div class="sf-page-header">
            <div>
                <div class="sf-page-kicker">Dashboard Overview</div>

                <h1>
                    Good evening, Jay 👋
                </h1>

                <p>
                    You have 3 ingredients that should be used soon.
                </p>
            </div>

            <button class="sf-primary-button" onclick="document.getElementById('quick-add-section').scrollIntoView({ behavior: 'smooth' }); return false;">
                + Quick Add
            </button>
        </div>

        <div class="sf-stats-grid">
            <div class="sf-stat-card">
                <div class="sf-stat-title">Total Pantry Items</div>
                <div class="sf-stat-value">@(TotalItems)</div>
                <div class="sf-stat-caption">Nicely stocked</div>
            </div>

            <div class="sf-stat-card sf-stat-warning">
                <div class="sf-stat-title">Expiring Soon</div>
                <div class="sf-stat-value">6</div>
                <div class="sf-stat-caption">Needs attention</div>
            </div>

            <div class="sf-stat-card sf-stat-success">
                <div class="sf-stat-title">Meals Available</div>
                <div class="sf-stat-value">18</div>
                <div class="sf-stat-caption">Ready to cook</div>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-header">
            <div>
                <div class="sf-section-kicker">Urgent Ingredients</div>
                <h2>Use these ingredients first</h2>
            </div>

            <a href="/dashboard/expire" class="sf-text-link">Open workspace</a>
        </div>

        <div class="sf-expiring-list">
            <div class="sf-expiring-card sf-danger-card">
                <div class="sf-expiring-icon">🥛</div>

                <div class="sf-expiring-content">
                    <div class="sf-expiring-name">Milk</div>
                    <div class="sf-expiring-meta">
                        Expires tomorrow
                    </div>
                </div>

                <div class="sf-expiring-badge sf-danger-badge">
                    Urgent
                </div>
            </div>

            <div class="sf-expiring-card sf-warning-card">
                <div class="sf-expiring-icon">🍅</div>

                <div class="sf-expiring-content">
                    <div class="sf-expiring-name">Tomatoes</div>
                    <div class="sf-expiring-meta">
                        2 days left
                    </div>
                </div>

                <div class="sf-expiring-badge sf-warning-badge">
                    Soon
                </div>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-header">
            <div>
                <div class="sf-section-kicker">Suggested Recipes</div>
                <h2>Cook with what you already have</h2>
            </div>
        </div>

        <div class="sf-recipes-grid">
            <div class="sf-recipe-card">
                <img src="images/recipe1.svg" alt="Recipe" />

                <div class="sf-recipe-body">
                    <div class="sf-match-tag">
                        92% ingredient match
                    </div>

                    <h3>Vegetable Pasta Bowl</h3>

                    <p>
                        Uses tomatoes, spinach and onions from your pantry.
                    </p>
                </div>
            </div>

            <div class="sf-recipe-card">
                <img src="images/recipe2.svg" alt="Recipe" />

                <div class="sf-recipe-body">
                    <div class="sf-match-tag">
                        84% ingredient match
                    </div>

                    <h3>Fresh Stir Fry</h3>

                    <p>
                        Great way to use your vegetables before expiry.
                    </p>
                </div>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-header">
            <div>
                <div class="sf-section-kicker">Pantry Health</div>
                <h2>Keep your kitchen balanced</h2>
            </div>
        </div>

        <div class="sf-pantry-grid">
            <div class="sf-panel-card">
                <div class="sf-panel-title">Fresh Ingredients</div>

                <div class="sf-big-number">18</div>

                <div class="sf-panel-caption">
                    Most of your pantry is in great condition.
                </div>
            </div>

            <div class="sf-panel-card" id="quick-add-section">
                <div class="sf-panel-title">Quick Add</div>

                <input class="sf-input" placeholder="Ingredient name" />
                <select class="sf-input mt-2" aria-label="Category">
                    <option value="">Select category...</option>
                    <option value="dairy">Dairy</option>
                    <option value="vegetable">Vegetable</option>
                    <option value="fruit">Fruit</option>
                    <option value="meat">Meat</option>
                    <option value="grain">Grain</option>
                    <option value="seafood">Seafood</option>
                    <option value="beverage">Beverage</option>
                    <option value="snack">Snack</option>
                    <option value="condiment">Condiment</option>
                    <option value="frozen">Frozen</option>
                    <option value="other">Other</option>
                </select>
                <input class="sf-input" placeholder="Quantity" />
                <input class="sf-input" placeholder="Expiration date" />

                <button class="sf-primary-button sf-full-button">
                    Add Ingredient
                </button>
            </div>
        </div>
    </section>

    <section class="sf-section">
        <div class="sf-section-header">
            <div>
                <div class="sf-section-kicker">Weekly Insights</div>
                <h2>Your waste reduction progress</h2>
            </div>
        </div>

        <div class="sf-chart-card">
            <div class="sf-chart-bars">
                <div class="sf-bar-group">
                    <div class="sf-bar" style="height: 40%"></div>
                    <span>Mon</span>
                </div>

                <div class="sf-bar-group">
                    <div class="sf-bar" style="height: 65%"></div>
                    <span>Tue</span>
                </div>

                <div class="sf-bar-group">
                    <div class="sf-bar" style="height: 50%"></div>
                    <span>Wed</span>
                </div>

                <div class="sf-bar-group">
                    <div class="sf-bar" style="height: 85%"></div>
                    <span>Thu</span>
                </div>

                <div class="sf-bar-group">
                    <div class="sf-bar" style="height: 70%"></div>
                    <span>Fri</span>
                </div>
            </div>
        </div>
    </section>
</DashboardShell>

@code {
   private int TotalItems;

   protected override async Task OnInitializedAsync()
   {
       var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
       var userId = authState.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;

       if (userId != null)
       {
           TotalItems = await PantryService.GetTotalItemsAsync(userId);
       }
   }
}
