@page "/login"
@layout MainLayout

@using Microsoft.AspNetCore.Identity
@using SmartFoods.Web.Data
@using SmartFoods.Web.Models

@inject SignInManager<ApplicationUser> SignInManager
@inject NavigationManager Navigation

@code {
    // Added SupplyParameterFromForm attribute so static postbacks can bind the data
    [SupplyParameterFromForm]
    public LoginModel model { get; set; } = new();

    private string? errorMessage;

    private async Task HandleLogin()
    {
        errorMessage = null;

        var result =
            await SignInManager.PasswordSignInAsync(
                model.Email,
                model.Password,
                model.RememberMe,
                lockoutOnFailure: false
            );

        if (result.Succeeded)
        {
            Navigation.NavigateTo("/dashboard");
        }
        else
        {
            errorMessage = "Invalid email or password.";
        }
    }
}

<PageTitle>Login | SmartFoods</PageTitle>

<Navbar />

<div class="auth-page bg-gradient-to-b from-white via-green-50 to-white">

    <div class="auth-shell">

        <div class="auth-hero">

            <div class="landing-chip">
                Smart pantry intelligence
            </div>

            <h1>
                Welcome back to
                <span>SmartFoods</span>
            </h1>

            <p>
                Continue tracking ingredients, reducing waste,
                and discovering recipes built around what you already have.
            </p>

            <div class="auth-benefits">

                <div class="auth-benefit-card">
                    <div class="benefit-icon">✓</div>

                    <div>
                        <h3>Expiration tracking</h3>

                        <p>
                            Never forget ingredients hidden in your pantry.
                        </p>
                    </div>
                </div>

                <div class="auth-benefit-card">
                    <div class="benefit-icon">✓</div>

                    <div>
                        <h3>Smart recipe recommendations</h3>

                        <p>
                            Cook using ingredients you already own.
                        </p>
                    </div>
                </div>

                <div class="auth-benefit-card">
                    <div class="benefit-icon">✓</div>

                    <div>
                        <h3>Waste reduction insights</h3>

                        <p>
                            Understand your weekly food usage trends.
                        </p>
                    </div>
                </div>

            </div>

        </div>

        <div class="auth-card landing-glass shadow-xl">

            <div class="landing-orb orb-a"></div>
            <div class="landing-orb orb-b"></div>

            <div class="auth-card-content">

                <div class="auth-header">
                    <h2>Login</h2>

                    <p>
                        Access your pantry dashboard
                    </p>
                </div>

                <EditForm Model="model"
                          OnValidSubmit="HandleLogin"
                          FormName="LoginForm"
                          class="auth-form">

                    <DataAnnotationsValidator />

                    <ValidationSummary />

                    <div class="form-group">

                        <label>Email Address</label>
                        <!-- Swapped to @bind-value for standard static SSR model binding -->
                        <input type="email"
                               @bind-value="model.Email"
                               name="model.Email"
                               placeholder="you@example.com" />

                    </div>

                    <div class="form-group">

                        <label>Password</label>
                        <!-- Swapped to @bind-value for standard static SSR model binding -->
                        <input type="password"
                               @bind-value="model.Password"
                               name="model.Password"
                               placeholder="Enter your password" />

                    </div>

                    <div class="form-row">

                        <label class="remember-row">

                            <InputCheckbox @bind-Value="model.RememberMe" />

                            <span>
                                Remember me
                            </span>

                        </label>

                        <a href="#">
                            Forgot password?
                        </a>

                    </div>

                    @if (!string.IsNullOrWhiteSpace(errorMessage))
                    {
                        <div class="auth-error" style="color: #dc3545; font-weight: 600; font-size: 0.95rem;">
                            @errorMessage
                        </div>
                    }

                    <button type="submit" class="auth-button">
                        Login to Dashboard
                    </button>

                </EditForm>

                <div class="auth-divider">
                    <span>or continue with</span>
                </div>

                <div class="social-grid">

                    <button type="button"
                            class="social-button">
                        Google
                    </button>

                    <button type="button"
                            class="social-button">
                        Apple
                    </button>

                </div>

                <div class="auth-footer">

                    Don't have an account?

                    <a href="/register">
                        Get started
                    </a>

                </div>

            </div>

        </div>

    </div>

</div>
