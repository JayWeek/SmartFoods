<section id="insights" class="dashboard-panel animate-fade-in">
    <div class="dashboard-panel-head dashboard-panel-head-stack">
        <div>
            <h2 class="dashboard-panel-title">
                Weekly Waste Insights
            </h2>
            <p class="text-gray-600">A single trend line and outcome split so the page stays readable.</p>
        </div>
    </div>

    <MudChart T="double" ChartType="ChartType.Line"
              ChartSeries="@_series"
              ChartLabels="@_labels"
              Width="100%"
              Height="220px" />

    <div class="mt-4">
        <WasteChart />
    </div>
</section>

@code {
    private readonly List<ChartSeries<double>> _series = new double[] { 5, 3, 4, 2, 1, 2, 0 }.AsChartDataSet();

    private readonly string[] _labels = ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"];
}
